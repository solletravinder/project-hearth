# ── Hearth Configuration ────────────────────────────────────────
# Copy this to .env and fill in your values.
# All vars are prefixed HEARTH_ to avoid conflicts.

# Server
HEARTH_HOST=127.0.0.1
HEARTH_PORT=8765

# Provider selection: "local" | "ollama" | "openai"
HEARTH_CHAT_PROVIDER=ollama
HEARTH_EMBEDDING_PROVIDER=local

# The default model for chat (used by Ollama & OpenAI-compat)
HEARTH_DEFAULT_MODEL=qwen3:0.6b

# Remote provider URLs
HEARTH_OLLAMA_BASE_URL=http://localhost:11434
HEARTH_OPENAI_BASE_URL=http://localhost:11434/v1

# Local embedding model (sentence-transformers name)
HEARTH_EMBEDDING_MODEL=gte-small

# Performance profile: "fast" | "balanced" | "accurate"
HEARTH_ACTIVE_PROFILE=balanced

# Device
HEARTH_DEVICE=cpu
